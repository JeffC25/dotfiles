theme = dark:"Sonokai", light:"Ayu light"
maximize = true
macos-option-as-alt = true

cursor-style-blink = true
# cursor-color = #86B300
# cursor-text = #FFFFFF
cursor-text = #86B300
# cursor-style = bar

macos-icon = official
macos-titlebar-proxy-icon = hidden
macos-titlebar-style = transparent
macos-window-shadow = false
# macos-window-buttons = hidden
# window-decoration = none
title = ""
window-subtitle = false

window-padding-x = 32
window-padding-y = 16,16
window-inherit-working-directory = true

background-opacity = 1
background-blur = 20
unfocused-split-opacity = 1

mouse-hide-while-typing = true
font-family = "JetBrains Mono"

# cmd + number → send tmux prefix (Ctrl-b) then that number
keybind = global:cmd+digit_0=text:\x00\x30
keybind = global:cmd+digit_1=text:\x00\x31
keybind = global:cmd+digit_2=text:\x00\x32
keybind = global:cmd+digit_3=text:\x00\x33
keybind = global:cmd+digit_4=text:\x00\x34
keybind = global:cmd+digit_5=text:\x00\x35
keybind = global:cmd+digit_6=text:\x00\x36
keybind = global:cmd+digit_7=text:\x00\x37
keybind = global:cmd+digit_8=text:\x00\x38
keybind = global:cmd+digit_9=text:\x00\x39

# new tmux window (Cmd+T)
keybind = cmd+t=text:\x00c

# vertical split (Cmd+D)
keybind = cmd+d=text:\x00%

# horizontal split (Cmd+Shift+D)
keybind = cmd+shift+d=text:\x00"

# close pane (Cmd+W)
keybind = cmd+w=text:exit\n

# detach tmux (Cmd+Shift+W)
keybind = cmd+shift+w=text:\x00d

# shaders
# custom-shader = shaders/ghostty-cursor-trails/boo-cursor.glsl
# custom-shader = shaders/ghostty-cursor-shaders/cursor_tail.glsl
custom-shader = shaders/ghostty-cursor-shaders/cursor_warp.glsl
custom-shader-animation = always
